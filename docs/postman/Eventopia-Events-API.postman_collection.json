{
  "info": {
    "name": "Eventopia Events API (by Role)",
    "description": "Event module APIs grouped by role: **Buyer** (public events + orders), **Promoter** (event CRUD, ticket types, scanner, access), **Admin** (list, complete, cancel, audit, metrics).\n\nBase URL: `{{baseUrl}}` (e.g. http://localhost:3000)\nAuth: Set `{{token}}` for routes that require Bearer token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "eventId", "value": "1" },
    { "key": "orderId", "value": "1" },
    { "key": "ticketId", "value": "1" },
    { "key": "ticketTypeId", "value": "1" },
    { "key": "shareToken", "value": "" },
    { "key": "imageId", "value": "" }
  ],
  "item": [
    {
      "name": "Buyer (Public + Orders)",
      "item": [
        {
          "name": "Public Events",
          "item": [
            {
              "name": "List public events",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/events?city=&categoryId=&tagIds=&dateFrom=&dateTo=&search=&sort=soonest&page=1&pageSize=20",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "events"],
                  "query": [
                    { "key": "city", "value": "" },
                    { "key": "categoryId", "value": "" },
                    { "key": "tagIds", "value": "" },
                    { "key": "dateFrom", "value": "" },
                    { "key": "dateTo", "value": "" },
                    { "key": "search", "value": "" },
                    { "key": "sort", "value": "soonest", "description": "soonest | newest | popular" },
                    { "key": "page", "value": "1" },
                    { "key": "pageSize", "value": "20" }
                  ]
                },
                "description": "List published public events. No auth. Query: city, categoryId, tagIds, dateFrom, dateTo, search, sort, page, pageSize."
              },
              "response": [
                {
                  "name": "Success",
                  "status": "OK",
                  "code": 200,
                  "body": "{\n  \"error\": false,\n  \"data\": {\n    \"items\": [\n      {\n        \"id\": 1,\n        \"title\": \"Sample Event\",\n        \"startAt\": \"2026-03-15T19:00:00.000Z\",\n        \"endAt\": \"2026-03-15T23:00:00.000Z\",\n        \"city\": \"London\",\n        \"venueName\": \"The Venue\",\n        \"format\": \"in_person\",\n        \"accessMode\": \"ticketed\",\n        \"category\": { \"id\": 1, \"name\": \"Music\" },\n        \"tags\": [],\n        \"coverImageUrl\": \"/uploads/cover.jpg\",\n        \"ticketsSold\": 10\n      }\n    ],\n    \"pagination\": { \"page\": 1, \"pageSize\": 20, \"total\": 1 }\n  },\n  \"meta\": { \"requestId\": \"\", \"timestamp\": \"\" }\n}"
                }
              ]
            },
            {
              "name": "Get event detail (public)",
              "request": {
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}/api/events/{{eventId}}",
                "description": "Full event detail + public ticket types for a published public event. No auth."
              },
              "response": [
                {
                  "name": "Success",
                  "status": "OK",
                  "code": 200,
                  "body": "{\n  \"error\": false,\n  \"data\": {\n    \"event\": {\n      \"id\": 1,\n      \"title\": \"Sample Event\",\n      \"description\": \"Description\",\n      \"startAt\": \"2026-03-15T19:00:00.000Z\",\n      \"endAt\": \"2026-03-15T23:00:00.000Z\",\n      \"timezone\": \"Europe/London\",\n      \"city\": \"London\",\n      \"venueName\": \"The Venue\",\n      \"venueAddress\": \"123 Street\",\n      \"format\": \"in_person\",\n      \"accessMode\": \"ticketed\",\n      \"category\": { \"id\": 1, \"name\": \"Music\" },\n      \"tags\": [],\n      \"promoter\": { \"id\": 1, \"name\": \"Promoter Name\" },\n      \"images\": []\n    },\n    \"ticketTypes\": [\n      {\n        \"id\": 1,\n        \"name\": \"General\",\n        \"currency\": \"GBP\",\n        \"priceAmount\": 1050,\n        \"bookingFeeAmount\": 235,\n        \"totalAmount\": 1285,\n        \"capacityTotal\": 100,\n        \"capacitySold\": 10,\n        \"capacityRemaining\": 90,\n        \"perOrderLimit\": 10,\n        \"status\": \"active\"\n      }\n    ]\n  }\n}"
                }
              ]
            },
            {
              "name": "Get event by private share link",
              "request": {
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}/api/events/share/{{shareToken}}",
                "description": "Event detail for private-link event; sets access grant cookie for ordering. No auth."
              },
              "response": [
                {
                  "name": "Success",
                  "status": "OK",
                  "code": 200,
                  "body": "{\n  \"error\": false,\n  \"data\": {\n    \"event\": { \"id\": 1, \"title\": \"Private Event\", \"ticketTypes\": [] },\n    \"ticketTypes\": []\n  }\n}"
                }
              ]
            }
          ]
        },
        {
          "name": "Orders (Buyer)",
          "item": [
            {
              "name": "Create order (tickets)",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"idempotencyKey\": \"{{$guid}}\",\n  \"items\": [\n    { \"ticketTypeId\": 1, \"quantity\": 2, \"buyerName\": \"John\", \"buyerEmail\": \"john@example.com\" }\n  ]\n}"
                },
                "url": "{{baseUrl}}/api/orders/events/{{eventId}}/orders",
                "description": "Create order (basket) for tickets. Auth required. Reserves inventory; payment via checkout."
              },
              "response": [
                {
                  "name": "Success",
                  "status": "OK",
                  "code": 200,
                  "body": "{\n  \"error\": false,\n  \"data\": {\n    \"orderId\": 1,\n    \"status\": \"PENDING\",\n    \"totalAmount\": 2570,\n    \"currency\": \"GBP\",\n    \"expiresAt\": \"2026-03-05T12:30:00.000Z\"\n  }\n}"
                }
              ]
            },
            {
              "name": "Checkout order",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "body": { "mode": "raw", "raw": "{}" },
                "url": "{{baseUrl}}/api/orders/{{orderId}}/checkout",
                "description": "Complete payment for order; confirm tickets. Auth + order ownership required."
              },
              "response": [
                {
                  "name": "Success",
                  "status": "OK",
                  "code": 200,
                  "body": "{\n  \"error\": false,\n  \"data\": { \"orderId\": 1, \"status\": \"PAID\", \"ticketIds\": [1, 2] }\n}"
                }
              ]
            },
            {
              "name": "Get my orders",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "url": "{{baseUrl}}/api/orders/me/orders",
                "description": "List current user's orders. Auth required."
              },
              "response": [
                {
                  "name": "Success",
                  "status": "OK",
                  "code": 200,
                  "body": "{\n  \"error\": false,\n  \"data\": { \"items\": [], \"pagination\": { \"page\": 1, \"pageSize\": 20, \"total\": 0 } }\n}"
                }
              ]
            },
            {
              "name": "Get my tickets",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "url": "{{baseUrl}}/api/orders/me/tickets",
                "description": "List current user's tickets. Auth required."
              },
              "response": [
                {
                  "name": "Success",
                  "status": "OK",
                  "code": 200,
                  "body": "{\n  \"error\": false,\n  \"data\": { \"items\": [] }\n}"
                }
              ]
            },
            {
              "name": "Get order detail",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "url": "{{baseUrl}}/api/orders/{{orderId}}",
                "description": "Get single order. Auth + order ownership required."
              },
              "response": []
            },
            {
              "name": "Get order tickets",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "url": "{{baseUrl}}/api/orders/{{orderId}}/tickets",
                "description": "Get tickets for an order. Auth + order ownership required."
              },
              "response": []
            },
            {
              "name": "Get ticket detail",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "url": "{{baseUrl}}/api/orders/tickets/{{ticketId}}",
                "description": "Get single ticket. Auth required."
              },
              "response": []
            },
            {
              "name": "Get ticket QR",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "url": "{{baseUrl}}/api/orders/tickets/{{ticketId}}/qr",
                "description": "Get QR payload for ticket. Auth required."
              },
              "response": []
            },
            {
              "name": "Cancel order",
              "request": {
                "method": "POST",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "url": "{{baseUrl}}/api/orders/{{orderId}}/cancel",
                "description": "Cancel an order. Auth + order ownership required."
              },
              "response": []
            }
          ]
        }
      ]
    },
    {
      "name": "Promoter",
      "item": [
        {
          "name": "Events CRUD",
          "item": [
            {
              "name": "Create event (draft)",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"title\": \"My Event\",\n  \"description\": \"Description\",\n  \"startAt\": \"2026-04-01T19:00:00.000Z\",\n  \"endAt\": \"2026-04-01T23:00:00.000Z\",\n  \"timezone\": \"Europe/London\",\n  \"format\": \"in_person\",\n  \"accessMode\": \"ticketed\",\n  \"visibilityMode\": \"public\",\n  \"city\": \"London\",\n  \"venueName\": \"The Venue\",\n  \"venueAddress\": \"123 Street\",\n  \"categoryId\": 1,\n  \"tagIds\": [1],\n  \"tagNames\": []\n}"
                },
                "url": "{{baseUrl}}/api/promoters/events",
                "description": "Create draft event. Auth: promoter, active. Then add ticket types, images, publish."
              },
              "response": [
                {
                  "name": "Success",
                  "status": "OK",
                  "code": 200,
                  "body": "{\n  \"error\": false,\n  \"data\": { \"id\": 1, \"message\": \"Event created\" }\n}"
                }
              ]
            },
            {
              "name": "List my events",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "url": {
                  "raw": "{{baseUrl}}/api/promoters/events?status=&sort=&page=1&pageSize=20&search=",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "promoters", "events"],
                  "query": [
                    { "key": "status", "value": "" },
                    { "key": "sort", "value": "" },
                    { "key": "page", "value": "1" },
                    { "key": "pageSize", "value": "20" },
                    { "key": "search", "value": "" }
                  ]
                },
                "description": "List events owned by promoter (any status). Auth: promoter."
              },
              "response": [
                {
                  "name": "Success",
                  "status": "OK",
                  "code": 200,
                  "body": "{\n  \"error\": false,\n  \"data\": {\n    \"items\": [\n      {\n        \"id\": 1,\n        \"title\": \"My Event\",\n        \"status\": \"draft\",\n        \"startAt\": \"2026-04-01T19:00:00.000Z\",\n        \"endAt\": \"2026-04-01T23:00:00.000Z\",\n        \"city\": \"London\",\n        \"venueName\": \"The Venue\",\n        \"tickets_sold\": 0,\n        \"capacityTotal\": 100,\n        \"coverImageUrl\": null\n      }\n    ],\n    \"pagination\": { \"page\": 1, \"pageSize\": 20, \"total\": 1 }\n  }\n}"
                }
              ]
            },
            {
              "name": "Get event detail (promoter)",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "url": "{{baseUrl}}/api/promoters/events/{{eventId}}",
                "description": "Full event detail for editing. Auth: promoter + event ownership."
              },
              "response": [
                {
                  "name": "Success",
                  "status": "OK",
                  "code": 200,
                  "body": "{\n  \"error\": false,\n  \"data\": {\n    \"id\": 1,\n    \"title\": \"My Event\",\n    \"description\": \"\",\n    \"start_at\": \"2026-04-01T19:00:00.000Z\",\n    \"end_at\": \"2026-04-01T23:00:00.000Z\",\n    \"status\": \"draft\",\n    \"ticketTypes\": [],\n    \"tags\": [],\n    \"promoter_name\": \"\",\n    \"category_name\": \"\"\n  }\n}"
                }
              ]
            },
            {
              "name": "Update event",
              "request": {
                "method": "PATCH",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"title\": \"Updated Title\",\n  \"description\": \"Updated description\"\n}"
                },
                "url": "{{baseUrl}}/api/promoters/events/{{eventId}}",
                "description": "Update event (partial). Cancelled events cannot be edited. Auth: promoter + event ownership."
              },
              "response": []
            },
            {
              "name": "Delete event",
              "request": {
                "method": "DELETE",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "url": "{{baseUrl}}/api/promoters/events/{{eventId}}",
                "description": "Delete event (soft/hard per implementation). Auth: promoter + event ownership."
              },
              "response": []
            }
          ]
        },
        {
          "name": "V1 Events (create with tiers)",
          "item": [
            {
              "name": "Create event with ticket tiers (v1)",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"title\": \"Quick Event\",\n  \"event_date\": \"2026-04-01T19:00:00.000Z\",\n  \"description\": \"Description\",\n  \"venue\": \"The Venue\",\n  \"ticket_tiers\": [\n    { \"tier_name\": \"General\", \"ticket_price\": 10.5, \"quantity_available\": 100 },\n    { \"tier_name\": \"VIP\", \"ticket_price\": 25, \"quantity_available\": 20 }\n  ]\n}"
                },
                "url": "{{baseUrl}}/api/v1/events",
                "description": "Create draft event with ticket tiers in one request. Auth: promoter."
              },
              "response": [
                {
                  "name": "Success",
                  "status": "OK",
                  "code": 200,
                  "body": "{\n  \"error\": false,\n  \"data\": { \"event_id\": \"1\", \"status\": \"draft\", \"title\": \"Quick Event\", \"created_at\": \"\" }\n}"
                }
              ]
            },
            {
              "name": "List my events (v1, with filters)",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/events/my?status=&search=&sort=soonest&page=1&limit=20",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "events", "my"],
                  "query": [
                    { "key": "status", "value": "", "description": "draft | published | live | completed | cancelled" },
                    { "key": "search", "value": "" },
                    { "key": "sort", "value": "soonest", "description": "soonest | oldest | title_asc | title_desc | tickets_sold" },
                    { "key": "page", "value": "1" },
                    { "key": "limit", "value": "20" }
                  ]
                },
                "description": "List promoter events with search, sort, filter, pagination. Auth: promoter."
              },
              "response": [
                {
                  "name": "Success",
                  "status": "OK",
                  "code": 200,
                  "body": "{\n  \"error\": false,\n  \"data\": {\n    \"events\": [\n      {\n        \"event_id\": \"1\",\n        \"title\": \"My Event\",\n        \"status\": \"published\",\n        \"event_date\": \"2026-04-01T19:00:00.000Z\",\n        \"tickets_sold\": 2,\n        \"gross_revenue_in_escrow\": 11000,\n        \"payout_status\": \"pending\"\n      }\n    ],\n    \"total\": 1\n  }\n}"
                }
              ]
            },
            {
              "name": "Export my events (CSV)",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "url": "{{baseUrl}}/api/v1/events/my/export?status=&search=&sort=soonest",
                "description": "Download promoter events as CSV. Same query params as list. Auth: promoter."
              },
              "response": []
            },
            {
              "name": "Get event detail (v1, public/owner)",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}", "disabled": true }],
                "url": "{{baseUrl}}/api/v1/events/{{eventId}}",
                "description": "Event detail; public if published; draft only if owner. Auth optional."
              },
              "response": []
            }
          ]
        },
        {
          "name": "Images",
          "item": [
            {
              "name": "Upload cover image",
              "request": {
                "method": "POST",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    { "key": "image", "type": "file", "src": "", "description": "Image file" }
                  ]
                },
                "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/images?type=cover",
                "description": "Upload cover image. multipart, field name 'image'. Auth: promoter + event ownership."
              },
              "response": [
                {
                  "name": "Success",
                  "status": "OK",
                  "code": 200,
                  "body": "{\n  \"error\": false,\n  \"data\": { \"mediaId\": 1, \"coverImageUrl\": \"/uploads/cover-123.jpg\" }\n}"
                }
              ]
            },
            {
              "name": "Upload gallery image",
              "request": {
                "method": "POST",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    { "key": "image", "type": "file", "src": "" }
                  ]
                },
                "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/images?type=gallery",
                "description": "Upload gallery image (max 10 per event). Auth: promoter + event ownership."
              },
              "response": []
            },
            {
              "name": "Delete cover",
              "request": {
                "method": "DELETE",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/cover",
                "description": "Remove cover image. Auth: promoter + event ownership."
              },
              "response": []
            },
            {
              "name": "Delete gallery image",
              "request": {
                "method": "DELETE",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/gallery/{{imageId}}",
                "description": "Remove one gallery image. imageId = event_media.id. Auth: promoter + event ownership."
              },
              "response": []
            },
            {
              "name": "Reorder gallery images",
              "request": {
                "method": "PATCH",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"imageOrder\": [3, 1, 2]\n}"
                },
                "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/images/reorder",
                "description": "Reorder gallery by array of image IDs. Auth: promoter + event ownership."
              },
              "response": []
            }
          ]
        },
        {
          "name": "Category & Tags",
          "item": [
            {
              "name": "Set event category",
              "request": {
                "method": "PUT",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "body": { "mode": "raw", "raw": "{\n  \"categoryId\": 1\n}" },
                "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/category",
                "description": "Set or clear event category. Auth: promoter + event ownership."
              },
              "response": []
            },
            {
              "name": "Set event tags",
              "request": {
                "method": "PUT",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"tagIds\": [1, 2],\n  \"tagNames\": [\"Music\", \"Live\"]\n}"
                },
                "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/tags",
                "description": "Replace event tags. Auth: promoter + event ownership."
              },
              "response": []
            }
          ]
        },
        {
          "name": "Lifecycle (publish, pause, cancel, complete)",
          "item": [
            {
              "name": "Publish event",
              "request": {
                "method": "POST",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/publish",
                "description": "Move draft to published. Requires required fields + at least one active ticket type. Auth: promoter + event ownership."
              },
              "response": [
                {
                  "name": "Success",
                  "status": "OK",
                  "code": 200,
                  "body": "{\n  \"error\": false,\n  \"data\": { \"id\": 1, \"status\": \"published\", \"publishedAt\": \"2026-03-05T12:00:00.000Z\" }\n}"
                }
              ]
            },
            {
              "name": "Pause event",
              "request": {
                "method": "POST",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/pause",
                "description": "Unpublish event (hide from listing, no new sales). Auth: promoter + event ownership."
              },
              "response": []
            },
            {
              "name": "Cancel event (promoter)",
              "request": {
                "method": "POST",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/cancel",
                "description": "Cancel event (promoter-initiated). Auth: promoter + event ownership."
              },
              "response": []
            },
            {
              "name": "Republish event",
              "request": {
                "method": "POST",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/republish",
                "description": "Make paused event published again. Auth: promoter + event ownership."
              },
              "response": []
            },
            {
              "name": "Complete event (promoter)",
              "request": {
                "method": "POST",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/complete",
                "description": "Mark event as completed. Auth: promoter + event ownership."
              },
              "response": []
            }
          ]
        },
        {
          "name": "Ticket types",
          "item": [
            {
              "name": "List ticket types",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/ticket-types",
                "description": "List ticket types for event. Auth: promoter + event ownership."
              },
              "response": [
                {
