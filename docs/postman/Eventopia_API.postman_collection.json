{
  "info": {
    "name": "Eventopia API",
    "description": "Eventopia backend API — run **Auth > Login** first, then use Promoter or Guru folders. Token is saved automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{accessToken}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "accessToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Run **Register** then **Login**. Use **Get Me** to verify token. Token is auto-saved from Login.",
      "item": [
        {
          "name": "Register (Promoter)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"promoter@example.com\",\n  \"password\": \"YourSecurePass123!\",\n  \"name\": \"Promoter Name\",\n  \"role\": \"promoter\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register",
            "description": "Register as promoter. Returns challengeId/otp for email verification. Then call OTP Verify."
          }
        },
        {
          "name": "Register (Guru)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"guru@example.com\",\n  \"password\": \"YourSecurePass123!\",\n  \"name\": \"Guru Name\",\n  \"role\": \"guru\",\n  \"invite_token\": \"optional-invite-token\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register",
            "description": "Register as guru. May require invite_token from Network Manager."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"promoter@example.com\",\n  \"password\": \"YourSecurePass123!\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Login. Saves accessToken to collection; all other requests use it as Bearer."
          }
        },
        {
          "name": "Verify OTP (Email)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"promoter@example.com\",\n  \"challengeId\": \"from-register-response\",\n  \"otp\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/otp/verify",
            "description": "Verify email OTP after promoter/guru registration."
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/refresh",
            "description": "Get new access token using refresh token from login."
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/auth/me",
            "description": "Current user profile. Requires Bearer token."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/auth/logout",
            "description": "Invalidate current session. Requires Bearer token."
          }
        }
      ]
    },
    {
      "name": "Promoter",
      "description": "Promoter APIs. Requires active promoter account (approved). Auth: Bearer token from Login.",
      "item": [
        {
          "name": "Account",
          "item": [
            {
              "name": "Get My Profile",
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/api/promoters/me"
              }
            },
            {
              "name": "Setup Account",
              "request": {
                "method": "PUT",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Full Name\",\n  \"city\": \"London\"\n}"
                },
                "url": "{{baseUrl}}/api/promoters/setup-account"
              }
            },
            {
              "name": "Create Application",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{}" },
                "url": "{{baseUrl}}/api/promoters/applications"
              }
            },
            {
              "name": "Get My Application",
              "request": { "method": "GET", "url": "{{baseUrl}}/api/promoters/applications/me" }
            },
            {
              "name": "Edit Application",
              "request": {
                "method": "PATCH",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{}" },
                "url": "{{baseUrl}}/api/promoters/applications/me"
              }
            },
            {
              "name": "Pay Activation Fee",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{}" },
                "url": "{{baseUrl}}/api/promoters/applications/{{applicationId}}/payments"
              }
            }
          ]
        },
        {
          "name": "Events",
          "item": [
            {
              "name": "List My Events",
              "request": { "method": "GET", "url": "{{baseUrl}}/api/promoters/events" }
            },
            {
              "name": "Create Event",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"title\": \"My Event\",\n  \"description\": \"Description\",\n  \"startAt\": \"2025-03-01T18:00:00.000Z\",\n  \"endAt\": \"2025-03-01T23:00:00.000Z\",\n  \"timezone\": \"Europe/London\",\n  \"format\": \"in_person\",\n  \"accessMode\": \"ticketed\",\n  \"visibilityMode\": \"public\",\n  \"city\": \"London\",\n  \"venueName\": \"Venue Name\",\n  \"venueAddress\": \"123 Street\"\n}"
                },
                "url": "{{baseUrl}}/api/promoters/events",
                "description": "Creates draft. Optional: doorsOpenTime, streamUrl, ageRestriction, collectAttendeeNames, stopSaleAt, categoryId, tagIds, tagNames."
              }
            },
            {
              "name": "Get Event Detail",
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/api/promoters/events/{{eventId}}"
              }
            },
            {
              "name": "Update Event",
              "request": {
                "method": "PATCH",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"title\": \"Updated Title\",\n  \"description\": \"Updated description\"\n}"
                },
                "url": "{{baseUrl}}/api/promoters/events/{{eventId}}",
                "description": "If published and tickets sold, only description, coverImageUrl, endAt, stopSaleAt allowed."
              }
            },
            {
              "name": "Delete Event",
              "request": { "method": "DELETE", "url": "{{baseUrl}}/api/promoters/events/{{eventId}}" }
            },
            {
              "name": "Publish Event",
              "request": {
                "method": "POST",
                "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/publish",
                "description": "Validates required fields and at least one active ticket type. Returns eventSlug, publicEventUrl, referralLink, escrowStatus."
              }
            },
            {
              "name": "Pause Event",
              "request": { "method": "POST", "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/pause" }
            },
            {
              "name": "Cancel Event",
              "request": { "method": "POST", "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/cancel" }
            },
            {
              "name": "Republish Event",
              "request": { "method": "POST", "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/republish" }
            },
            {
              "name": "Complete Event",
              "request": { "method": "POST", "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/complete" }
            }
          ]
        },
        {
          "name": "Events - Images",
          "item": [
            {
              "name": "Upload Cover Image",
              "request": {
                "method": "POST",
                "body": {
                  "mode": "formdata",
                  "formdata": [{ "key": "image", "type": "file", "src": [] }]
                },
                "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/images?type=cover"
              }
            },
            {
              "name": "Upload Gallery Image",
              "request": {
                "method": "POST",
                "body": {
                  "mode": "formdata",
                  "formdata": [{ "key": "image", "type": "file", "src": [] }]
                },
                "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/images?type=gallery"
              }
            },
            {
              "name": "Delete Cover",
              "request": { "method": "DELETE", "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/cover" }
            },
            {
              "name": "Reorder Gallery",
              "request": {
                "method": "PATCH",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"imageOrder\": [2, 1, 3]\n}" },
                "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/images/reorder"
              }
            }
          ]
        },
        {
          "name": "Events - Category & Tags",
          "item": [
            {
              "name": "Set Category",
              "request": {
                "method": "PUT",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"categoryId\": 1\n}" },
                "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/category"
              }
            },
            {
              "name": "Set Tags",
              "request": {
                "method": "PUT",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"tagIds\": [1, 2],\n  \"tagNames\": [\"Music\", \"Live\"]\n}" },
                "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/tags"
              }
            }
          ]
        },
        {
          "name": "Ticket Types",
          "item": [
            {
              "name": "List Ticket Types",
              "request": { "method": "GET", "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/ticket-types" }
            },
            {
              "name": "Create Ticket Type",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"General Admission\",\n  \"priceAmount\": 2500,\n  \"bookingFeeAmount\": 250,\n  \"currency\": \"GBP\",\n  \"capacityTotal\": 100\n}"
                },
                "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/ticket-types"
              }
            },
            {
              "name": "Update Ticket Type",
              "request": {
                "method": "PATCH",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"name\": \"Updated Name\"\n}" },
                "url": "{{baseUrl}}/api/promoters/ticket-types/{{ticketTypeId}}"
              }
            },
            {
              "name": "Pause Ticket Type",
              "request": { "method": "POST", "url": "{{baseUrl}}/api/promoters/ticket-types/{{ticketTypeId}}/pause" }
            },
            {
              "name": "Resume Ticket Type",
              "request": { "method": "POST", "url": "{{baseUrl}}/api/promoters/ticket-types/{{ticketTypeId}}/resume" }
            },
            {
              "name": "Delete Ticket Type",
              "request": { "method": "DELETE", "url": "{{baseUrl}}/api/promoters/ticket-types/{{ticketTypeId}}" }
            },
            {
              "name": "Duplicate Ticket Type",
              "request": { "method": "POST", "url": "{{baseUrl}}/api/promoters/ticket-types/{{ticketTypeId}}/duplicate" }
            }
          ]
        },
        {
          "name": "Event Operations",
          "item": [
            { "name": "Get Event Performance", "request": { "method": "GET", "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/performance" }},
            { "name": "Get Attendees", "request": { "method": "GET", "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/attendees" }},
            {
              "name": "Validate Ticket",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"ticketId\": 1\n}" },
                "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/validate"
              }
            },
            {
              "name": "Check-in Ticket",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"ticketId\": 1\n}" },
                "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/checkin"
              }
            },
            { "name": "Get Event Logs", "request": { "method": "GET", "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/logs" }},
            { "name": "Get Access Settings", "request": { "method": "GET", "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/access-settings" }},
            { "name": "Update Access Settings", "request": { "method": "PATCH", "url": "{{baseUrl}}/api/promoters/events/{{eventId}}/access-settings" }}
          ]
        },
        {
          "name": "Dashboard & Rewards",
          "item": [
            { "name": "Dashboard Overview", "request": { "method": "GET", "url": "{{baseUrl}}/api/promoters/dashboard/overview" }},
            { "name": "Get My Rewards", "request": { "method": "GET", "url": "{{baseUrl}}/api/promoters/rewards" }}
          ]
        }
      ]
    },
    {
      "name": "Guru",
      "description": "Guru APIs. Requires guru role and active account. Auth: Bearer token from Login.",
      "item": [
        {
          "name": "Account",
          "item": [
            { "name": "Get My Profile", "request": { "method": "GET", "url": "{{baseUrl}}/api/gurus/me" }},
            {
              "name": "Setup Account",
              "request": {
                "method": "PUT",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"name\": \"Guru Name\"\n}" },
                "url": "{{baseUrl}}/api/gurus/setup-account"
              }
            },
            { "name": "Create Application", "request": { "method": "POST", "url": "{{baseUrl}}/api/gurus/applications" }},
            { "name": "Get My Application", "request": { "method": "GET", "url": "{{baseUrl}}/api/gurus/applications/me" }},
            { "name": "Update My Application", "request": { "method": "PATCH", "url": "{{baseUrl}}/api/gurus/applications/me" }},
            { "name": "Commit Activation Fee", "request": { "method": "POST", "url": "{{baseUrl}}/api/gurus/activation-fee/commit" }}
          ]
        },
        {
          "name": "Dashboard",
          "item": [
            { "name": "Dashboard Summary", "request": { "method": "GET", "url": "{{baseUrl}}/api/gurus/dashboard/summary" }},
            { "name": "Referral Info", "request": { "method": "GET", "url": "{{baseUrl}}/api/gurus/dashboard/referral" }},
            { "name": "Attached Promoters", "request": { "method": "GET", "url": "{{baseUrl}}/api/gurus/dashboard/promoters" }},
            { "name": "Promoter Performance", "request": { "method": "GET", "url": "{{baseUrl}}/api/gurus/dashboard/promoters/{{promoterId}}" }}
          ]
        },
        {
          "name": "Promoter Applications",
          "item": [
            { "name": "List Promoter Applications", "request": { "method": "GET", "url": "{{baseUrl}}/api/gurus/promoters/applications" }},
            { "name": "Approve Promoter", "request": { "method": "POST", "url": "{{baseUrl}}/api/gurus/promoters/{{applicationId}}/approve" }},
            { "name": "Reject Promoter", "request": { "method": "POST", "url": "{{baseUrl}}/api/gurus/promoters/{{applicationId}}/reject" }}
          ]
        },
        {
          "name": "Referral & Exports",
          "item": [
            { "name": "Referral Stats", "request": { "method": "GET", "url": "{{baseUrl}}/api/gurus/referral/stats" }},
            { "name": "Export Promoters CSV", "request": { "method": "GET", "url": "{{baseUrl}}/api/gurus/exports/promoters.csv" }},
            { "name": "Export Performance CSV", "request": { "method": "GET", "url": "{{baseUrl}}/api/gurus/exports/performance.csv" }}
          ]
        },
        {
          "name": "Marketing Hub",
          "item": [
            { "name": "Get Marketing Hub", "request": { "method": "GET", "url": "{{baseUrl}}/api/gurus/marketing-hub" }},
            { "name": "Submit Content", "request": { "method": "POST", "url": "{{baseUrl}}/api/gurus/marketing-hub/submissions" }},
            { "name": "Get My Submissions", "request": { "method": "GET", "url": "{{baseUrl}}/api/gurus/marketing-hub/submissions" }},
            { "name": "Request Campaign", "request": { "method": "POST", "url": "{{baseUrl}}/api/gurus/marketing-hub/campaign-requests" }},
            { "name": "Get Campaign Requests", "request": { "method": "GET", "url": "{{baseUrl}}/api/gurus/marketing-hub/campaign-requests" }},
            { "name": "Leaderboard", "request": { "method": "GET", "url": "{{baseUrl}}/api/gurus/leaderboard" }},
            { "name": "Levels Info", "request": { "method": "GET", "url": "{{baseUrl}}/api/gurus/levels/info" }},
            { "name": "Sprint Mode", "request": { "method": "GET", "url": "{{baseUrl}}/api/gurus/sprint-mode" }}
          ]
        },
        {
          "name": "Other",
          "item": [
            { "name": "Get My Rewards", "request": { "method": "GET", "url": "{{baseUrl}}/api/gurus/rewards" }},
            { "name": "License Info", "request": { "method": "GET", "url": "{{baseUrl}}/api/gurus/license/info" }},
            { "name": "Onboarding Checklist", "request": { "method": "GET", "url": "{{baseUrl}}/api/gurus/onboarding/checklist" }}
          ]
        }
      ]
    }
  ]
}
