{
  "info": {
    "name": "Eventopia API",
    "description": "Eventopia backend APIs by module and role. Set {{baseUrl}} (e.g. http://localhost:3000/api) and {{accessToken}} for auth.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "accessToken", "value": "" }
  ],
  "item": [
    {
      "name": "0. Health & Public",
      "item": [
        {
          "name": "Health (root)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "http://localhost:3000/health",
            "description": "Server health check. No auth. Returns status, uptime, version."
          }
        },
        {
          "name": "GET Public events list",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/events?page=1&pageSize=20&sort=soonest&city=&categoryId=&dateFrom=&dateTo=&search=",
            "description": "List published public events. Query: page, pageSize, sort (soonest|newest|popular), city, categoryId, tagIds, dateFrom, dateTo, search."
          }
        },
        {
          "name": "GET Event detail by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/events/{{eventId}}",
            "description": "Get single published public event with ticket types. Path: event id."
          }
        },
        {
          "name": "GET Event by share token",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/events/share/{{shareToken}}",
            "description": "Get private-link event by share token. Sets access cookie for ordering."
          }
        }
      ]
    },
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "POST Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePass123\",\n  \"name\": \"John Doe\"\n}"
            },
            "url": "{{baseUrl}}/auth/register",
            "description": "Email/password registration. Body: email, password, name."
          }
        },
        {
          "name": "POST Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePass123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Login. Returns accessToken, refreshToken, user. Set accessToken for subsequent requests."
          }
        },
        {
          "name": "POST Refresh token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}" },
            "url": "{{baseUrl}}/auth/refresh",
            "description": "Get new access token using refresh token."
          }
        },
        {
          "name": "GET Me (current user)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/auth/me",
            "description": "Get current authenticated user. Requires auth."
          }
        },
        {
          "name": "POST Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/auth/logout",
            "description": "Logout current session. Requires auth."
          }
        },
        {
          "name": "POST Verify email",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"verification_token_from_email\"\n}" },
            "url": "{{baseUrl}}/auth/verify-email",
            "description": "Verify email with token sent to user."
          }
        },
        {
          "name": "POST Forgot password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@example.com\"\n}" },
            "url": "{{baseUrl}}/auth/forgot-password",
            "description": "Request password reset email."
          }
        },
        {
          "name": "POST Reset password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"reset_token\",\n  \"new_password\": \"NewSecurePass123\"\n}" },
            "url": "{{baseUrl}}/auth/reset-password",
            "description": "Reset password with token from email."
          }
        }
      ]
    },
    {
      "name": "2. Buyer – Orders",
      "item": [
        {
          "name": "POST Create order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idempotencyKey\": \"unique-key-uuid\",\n  \"items\": [\n    { \"ticketTypeId\": 1, \"quantity\": 2 }\n  ]\n}"
            },
            "url": "{{baseUrl}}/orders/events/{{eventId}}/orders",
            "description": "Create order for event. Body: idempotencyKey (required), items[{ ticketTypeId, quantity }]. Returns orderId, totalAmount, expiresAt."
          }
        },
        {
          "name": "POST Checkout order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/orders/{{orderId}}/checkout",
            "description": "Complete payment for order. Confirms tickets."
          }
        },
        {
          "name": "GET My orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/orders/me/orders",
            "description": "List current user's orders."
          }
        },
        {
          "name": "GET My tickets",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/orders/me/tickets",
            "description": "List current user's tickets."
          }
        },
        {
          "name": "GET Order details",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/orders/{{orderId}}",
            "description": "Get single order. Requires order ownership."
          }
        },
        {
          "name": "GET Order tickets",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/orders/{{orderId}}/tickets",
            "description": "Get tickets for an order."
          }
        },
        {
          "name": "GET Ticket details",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/orders/tickets/{{ticketId}}",
            "description": "Get single ticket details."
          }
        },
        {
          "name": "GET Ticket QR",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/orders/tickets/{{ticketId}}/qr",
            "description": "Get QR payload for ticket."
          }
        },
        {
          "name": "POST Cancel order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/orders/{{orderId}}/cancel",
            "description": "Cancel an order (before payment)."
          }
        }
      ]
    },
    {
      "name": "3. Promoter – Events",
      "item": [
        {
          "name": "POST Create event",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My Event\",\n  \"description\": \"Description\",\n  \"startAt\": \"2026-06-01T19:00:00Z\",\n  \"endAt\": \"2026-06-01T23:00:00Z\",\n  \"format\": \"in_person\",\n  \"accessMode\": \"ticketed\",\n  \"visibilityMode\": \"public\",\n  \"city\": \"London\",\n  \"venueName\": \"Venue\",\n  \"venueAddress\": \"Address\"\n}"
            },
            "url": "{{baseUrl}}/promoters/events",
            "description": "Create draft event. Promoter must be active. Optional: categoryId, tagIds, tagNames."
          }
        },
        {
          "name": "GET My events",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/promoters/events",
            "description": "List promoter's events."
          }
        },
        {
          "name": "GET Event detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/promoters/events/{{eventId}}",
            "description": "Get single event (owner only)."
          }
        },
        {
          "name": "PATCH Update event",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Updated Title\"\n}" },
            "url": "{{baseUrl}}/promoters/events/{{eventId}}",
            "description": "Update draft event. Partial body allowed."
          }
        },
        {
          "name": "POST Publish event",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/promoters/events/{{eventId}}/publish",
            "description": "Publish event (requires required fields and at least one active ticket type)."
          }
        },
        {
          "name": "POST Pause event",
          "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/promoters/events/{{eventId}}/pause" }
        },
        {
          "name": "POST Cancel event",
          "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/promoters/events/{{eventId}}/cancel" }
        },
        {
          "name": "GET Event performance",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/promoters/events/{{eventId}}/performance",
            "description": "Get event sales/performance metrics."
          }
        }
      ]
    },
    {
      "name": "4. Promoter – Ticket types",
      "item": [
        {
          "name": "GET Ticket types",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/promoters/events/{{eventId}}/ticket-types",
            "description": "List ticket types for event."
          }
        },
        {
          "name": "POST Create ticket type",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"General\",\n  \"priceAmount\": 2500,\n  \"bookingFeeAmount\": 250,\n  \"capacityTotal\": 100,\n  \"perOrderLimit\": 10\n}"
            },
            "url": "{{baseUrl}}/promoters/events/{{eventId}}/ticket-types",
            "description": "Create ticket type. Amounts in pence."
          }
        },
        {
          "name": "PATCH Update ticket type",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Updated Name\",\n  \"priceAmount\": 3000\n}" },
            "url": "{{baseUrl}}/promoters/ticket-types/{{ticketTypeId}}",
            "description": "Update ticket type."
          }
        }
      ]
    },
    {
      "name": "5. Promoter – Charity",
      "item": [
        {
          "name": "POST Create charity application",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"charity_name\": \"Charity Name\",\n  \"charity_number\": \"123456\",\n  \"charity_description\": \"Desc\",\n  \"charitable_objectives\": \"Objectives\",\n  \"requested_amount\": 50000,\n  \"event_id\": null\n}"
            },
            "url": "{{baseUrl}}/promoters/charity/applications",
            "description": "Create charity application. Amount in pence."
          }
        },
        {
          "name": "GET My charity applications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/promoters/charity/applications",
            "description": "List promoter's charity applications."
          }
        },
        {
          "name": "GET Charity application",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/promoters/charity/applications/{{applicationId}}",
            "description": "Get single charity application."
          }
        },
        {
          "name": "POST Submit charity application",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/promoters/charity/applications/{{applicationId}}/submit",
            "description": "Submit application (moves to fee payment)."
          }
        },
        {
          "name": "POST Pay charity fee",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"idempotency_key\": \"unique-key-uuid\"\n}" },
            "url": "{{baseUrl}}/promoters/charity/applications/{{applicationId}}/pay-fee",
            "description": "Initiate charity application fee payment (open banking). Returns redirect_url."
          }
        }
      ]
    },
    {
      "name": "6. Admin – Events",
      "item": [
        {
          "name": "GET All events",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/admin/events?page=1&pageSize=50&status=&completionStatus=",
            "description": "List all events. Admin only. Query: page, pageSize, status, completionStatus."
          }
        },
        {
          "name": "GET Event by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/admin/events/{{eventId}}",
            "description": "Get any event. Admin only."
          }
        },
        {
          "name": "POST Complete event",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/admin/events/{{eventId}}/complete",
            "description": "Mark event completed and trigger rewards. Admin only."
          }
        },
        {
          "name": "POST Cancel event",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"reason\": \"Optional reason\"\n}" },
            "url": "{{baseUrl}}/admin/events/{{eventId}}/cancel",
            "description": "Cancel event. Admin only."
          }
        },
        {
          "name": "GET Event audit logs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/admin/events/audit-logs?eventId=&promoterId=&action=&page=1&pageSize=50",
            "description": "Event audit log entries. Admin only."
          }
        },
        {
          "name": "GET Event metrics",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/admin/events/metrics",
            "description": "Event dashboard metrics. Admin only."
          }
        }
      ]
    },
    {
      "name": "7. Admin – Charity",
      "item": [
        {
          "name": "GET Charity applications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/admin/charity/applications?status=&promoter_id=&date_from=&date_to=",
            "description": "List charity applications. Admin only."
          }
        },
        {
          "name": "GET Charity application",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/admin/charity/applications/{{applicationId}}",
            "description": "Get charity application with payments, decisions, executions. Admin only."
          }
        },
        {
          "name": "POST Approve charity",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"decision_amount\": 50000,\n  \"admin_notes\": \"Approved\"\n}" },
            "url": "{{baseUrl}}/admin/charity/applications/{{applicationId}}/approve",
            "description": "Approve with decision amount (pence). Admin only."
          }
        },
        {
          "name": "POST Partial approve charity",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"decision_amount\": 25000,\n  \"admin_notes\": \"Partial\"\n}" },
            "url": "{{baseUrl}}/admin/charity/applications/{{applicationId}}/partial-approve",
            "description": "Partially approve. Admin only."
          }
        },
        {
          "name": "POST Reject charity",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"rejection_reason\": \"Reason\",\n  \"admin_notes\": \"Notes\"\n}" },
            "url": "{{baseUrl}}/admin/charity/applications/{{applicationId}}/reject",
            "description": "Reject application. Admin only."
          }
        },
        {
          "name": "POST Execute charity payout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"recipient_type\": \"venue\",\n  \"recipient_name\": \"Venue Ltd\",\n  \"amount\": 10000,\n  \"execution_reference\": \"REF-123\",\n  \"recipient_details\": {}\n}"
            },
            "url": "{{baseUrl}}/admin/charity/applications/{{applicationId}}/execute",
            "description": "Create execution (venue/supplier/marketing_platform). Admin only. Amount in pence."
          }
        },
        {
          "name": "GET Charity balance",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/admin/charity/balance",
            "description": "Get charity pot balance. Admin only."
          }
        },
        {
          "name": "GET Charity ledger",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/admin/charity/ledger",
            "description": "Get charity ledger entries. Admin only."
          }
        }
      ]
    },
